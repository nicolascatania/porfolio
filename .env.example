# EmailJS Configuration
# Get these from your EmailJS dashboard: https://www.emailjs.com/
# 1. Log in to EmailJS
# 2. Go to Account > General > Copy your Public Key
# 3. Go to Email Services > Select Gmail Service > Copy Service ID
# 4. Go to Email Templates > Select your template > Copy Template ID

EMAILJS_SERVICE_ID=your_service_id_here
EMAILJS_TEMPLATE_ID=your_template_id_here
EMAILJS_PUBLIC_KEY=your_public_key_here